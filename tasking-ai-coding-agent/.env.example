# ── LLM ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-5

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./tasking.db

# ── Redis / Celery ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── GitHub ────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo-name          # default repo for PRs

# ── Sandbox ───────────────────────────────────────────────────────────
SANDBOX_IMAGE=python:3.12-slim       # Docker image used for code execution
SANDBOX_TIMEOUT=30                   # seconds

# ── App ───────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO
